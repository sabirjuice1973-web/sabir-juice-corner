enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model AiConversation {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  title     String?
  startedAt DateTime @default(now())
  endedAt   DateTime?

  user     User        @relation(fields: [userId], references: [id])
  messages AiMessage[]
}

model AiMessage {
  id             BigInt   @id @default(autoincrement())
  conversationId BigInt
  role           AiRole
  content        String   @db.Text
  toolCalls      Json?
  tokensUsed     Int?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum AiRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

// ─── Inventory Reconciliation ─────────────────────────────────────────────
//
// Per the owner's spec: reconciliation is fruit-level, NOT recipe-level.
// Each ProcessedProduct (pulp) has a configurable yield (medium glasses per shoper).
// Each Item has a list of participation percentages mapping it to one or more
// pulps. The math engine sums (qty × size_factor × participation_pct) per fruit,
// converts to shopers via yield, and compares against (opening + transfers − closing).
//
// Out of scope: recipe weights (grams/ml/kg), ingredient unit conversions,
// per-batch costs. Those are tracked elsewhere if needed.

// Versioned yield configuration: how many medium-glass equivalents one shoper
// of this pulp produces. Mirrors the ItemPrice pattern so the owner can edit
// seasonally (summer = more glass per shoper) without rewriting history.
//
// Lookup rule at query time:
//   active row = WHERE processedProductId = X
//                AND effectiveFrom <= businessDate
//                AND (effectiveTo IS NULL OR effectiveTo > businessDate)
//   Per-branch override (branchId set) wins over the org-wide row (branchId null).
model YieldConfig {
  id                 BigInt   @id @default(autoincrement())
  processedProductId BigInt
  branchId           BigInt?                       // null = org-wide; set = per-branch override
  glassesPerShoper   Decimal  @db.Decimal(10, 2)   // medium-glass equivalents per shoper
  effectiveFrom      DateTime @db.Date
  effectiveTo        DateTime? @db.Date            // null = currently active
  notes              String?
  createdById        BigInt?
  createdAt          DateTime @default(now())

  processedProduct ProcessedProduct @relation(fields: [processedProductId], references: [id], onDelete: Cascade)
  branch           Branch?          @relation(fields: [branchId], references: [id])
  createdBy        User?            @relation(fields: [createdById], references: [id])

  @@index([processedProductId, branchId, effectiveFrom])
}

// How much each pulp participates in producing a given Item.
//   Peach Medium      -> [{ Peach Pulp, 100 }]
//   Peach+Plum Medium -> [{ Peach Pulp, 50 }, { Plum Pulp, 50 }]
//   Peach+Plum+Falsa  -> 3 rows at 33.3333 each (last row absorbs rounding to total 100)
// One row per (Item, ProcessedProduct) pair. Owner can review/override in admin.
model ItemParticipation {
  id                 BigInt   @id @default(autoincrement())
  itemId             BigInt
  processedProductId BigInt
  participationPct   Decimal  @db.Decimal(8, 4)    // e.g. 100.0000, 50.0000, 33.3333, 25.0000
  isAutoSeeded       Boolean  @default(false)      // true if seeded by name-parse; owner has not reviewed
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  item             Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  processedProduct ProcessedProduct @relation(fields: [processedProductId], references: [id], onDelete: Cascade)

  @@unique([itemId, processedProductId])
  @@index([processedProductId])
}

// One reconciliation per branch per business day. Lifecycle:
//   DRAFT             -> opening just confirmed; day is in progress, sales accumulating
//   PENDING_CLOSE     -> manager opened the close screen but hasn't submitted yet
//   PENDING_REASONS   -> submitted, but variance > 5% on some lines needs a reason
//   CLOSED            -> all required reasons recorded, day fully reconciled
model StockReconciliation {
  id                     BigInt   @id @default(autoincrement())
  branchId               BigInt
  businessDate           DateTime @db.Date
  status                 ReconciliationStatus @default(DRAFT)
  // Opening confirmation — morning manager either accepts last night's closing
  // as today's opening, or overrides + leaves a note.
  openingConfirmedById   BigInt?
  openingConfirmedAt     DateTime?
  openingOverrideNote    String?
  // Closing — night manager
  closedById             BigInt?
  closedAt               DateTime?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  branch              Branch                    @relation(fields: [branchId], references: [id])
  openingConfirmedBy  User?                     @relation("recon_opening_by", fields: [openingConfirmedById], references: [id])
  closedBy            User?                     @relation("recon_closed_by",  fields: [closedById],           references: [id])
  lines               StockReconciliationLine[]

  @@unique([branchId, businessDate])
  @@index([branchId, status])
}

enum ReconciliationStatus {
  DRAFT
  PENDING_CLOSE
  PENDING_REASONS
  CLOSED
}

// ─── Customer / Partner Accounts (creditors ledger) ─────────────────────
//
// Per the owner: orders go to credit accounts in three flavours:
//   FOODPANDA   one account per branch, billing cycle Mon-Sun, payment Tue
//   MARKET      shopkeepers nearby — push-to-account from Box 7 by name
//   CUSTOMER    walk-in credit customers — push-to-account from Boxes 1-5
// Orders pushed to an Account stay PAID (revenue recognised on delivery),
// payment method = CREDIT, and Order.accountId is set. The balance accumulates
// until an AccountPayment row settles it. Cash flow is tracked via AccountPayment;
// the balance column is a cached running total recomputed from Order.total - AccountPayment.amount.
model Account {
  id        BigInt   @id @default(autoincrement())
  branchId  BigInt
  name      String                              // "Food Panda", "Ali Shopkeeper", customer name
  type      AccountType
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branch   Branch           @relation(fields: [branchId], references: [id])
  orders   Order[]
  payments AccountPayment[]

  // One account per (branch, name, type) — multi-typed names allowed across types.
  @@unique([branchId, name, type])
  @@index([branchId, type, isActive])
}

enum AccountType {
  FOODPANDA
  MARKET
  CUSTOMER
}

// A payment received against an Account. Owner enters the cash received + any
// commission/discount writeoff; the system tracks balance via aggregation.
// Optionally, the payment may be linked to specific Orders being settled (so the
// owner has a per-order audit trail of which payment cleared which bills).
model AccountPayment {
  id            BigInt   @id @default(autoincrement())
  accountId     BigInt
  amount        Decimal  @db.Decimal(12, 2)             // cash actually received
  discount      Decimal  @db.Decimal(12, 2) @default(0) // written off (e.g. food panda commission)
  method        PaymentMethod
  reference     String?                                  // bank-transfer id, cheque #, etc.
  paidAt        DateTime @default(now())
  businessDate  DateTime @db.Date
  notes         String?
  recordedById  BigInt?
  createdAt     DateTime @default(now())

  account     Account                    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  recordedBy  User?                      @relation("account_payment_by", fields: [recordedById], references: [id])
  orderLinks  AccountPaymentOrderLink[]

  @@index([accountId, paidAt])
}

// Join row: which orders this payment is settling.
// The owner can split one payment across many orders; the sum of order totals
// covered (minus discount) should match the payment amount, but we don't enforce
// that strictly — the balance recomputation is the source of truth.
model AccountPaymentOrderLink {
  id         BigInt @id @default(autoincrement())
  paymentId  BigInt
  orderId    BigInt
  appliedAmount Decimal @db.Decimal(12, 2)   // how much of this payment is applied to that order

  payment AccountPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  order   Order          @relation(fields: [orderId], references: [id])

  @@unique([paymentId, orderId])
  @@index([orderId])
}

// One row per pulp per reconciliation. Holds opening/closing quantities and the
// computed expected vs actual, plus the reason code if variance was significant.
//   expectedConsumptionMGE = sum over sales today of (qty * sizeFactor * participationPct)
//   expectedConsumptionShopers = expectedConsumptionMGE / glassesPerShoper(yield)
//   expectedCloseQty = openingQty + transfersInQty - expectedConsumptionShopers
//   varianceQty      = closingQty - expectedCloseQty   (positive = surplus, negative = deficit)
//   variancePct      = varianceQty / expectedCloseQty * 100
// openingFromPrevClose records what the previous night's closing was, so we
// can detect overrides (morning manager entered something different).
model StockReconciliationLine {
  id                          BigInt   @id @default(autoincrement())
  reconciliationId            BigInt
  processedProductId          BigInt
  openingQty                  Decimal  @db.Decimal(14, 3)
  openingFromPrevClose        Decimal? @db.Decimal(14, 3)
  transfersInQty              Decimal  @db.Decimal(14, 3) @default(0)
  glassesPerShoperUsed        Decimal  @db.Decimal(10, 2)   // snapshot of the yield used today
  expectedConsumptionMGE      Decimal? @db.Decimal(14, 3)
  expectedConsumptionShopers  Decimal? @db.Decimal(14, 3)
  expectedCloseQty            Decimal? @db.Decimal(14, 3)
  closingQty                  Decimal? @db.Decimal(14, 3)
  varianceQty                 Decimal? @db.Decimal(14, 3)
  variancePct                 Decimal? @db.Decimal(8, 2)
  reasonCode                  String?                       // SPILLED | BROKEN | REPLACEMENT | WASTAGE | STAFF_MISTAKE | GIVEAWAY | ROUNDING | OTHER
  reasonNotes                 String?
  reasonRecordedById          BigInt?
  reasonRecordedAt            DateTime?

  reconciliation     StockReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  processedProduct   ProcessedProduct    @relation(fields: [processedProductId], references: [id])
  reasonRecordedBy   User?               @relation("recon_reason_by", fields: [reasonRecordedById], references: [id])

  @@unique([reconciliationId, processedProductId])
}

// ─── Expense / Khatabook Ledger ───────────────────────────────────────────
//
// 10 named expense-book accounts per branch. Each account can hold unlimited
// entries: purchasing, salaries, daily expenses, etc. Separate from the
// credit-customer "Account" model above. The owner can rename accounts freely.

model LedgerAccount {
  id        BigInt   @id @default(autoincrement())
  branchId  BigInt
  position  Int      // 1-10, fixed slot number
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch  Branch        @relation(fields: [branchId], references: [id])
  entries LedgerEntry[]

  @@unique([branchId, position])
  @@index([branchId])
}

model LedgerEntry {
  id              BigInt   @id @default(autoincrement())
  branchId        BigInt
  ledgerAccountId BigInt
  entryDate       DateTime @db.Date
  productName     String
  quantity        Decimal? @db.Decimal(14, 3)
  rate            Decimal? @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  headName        String?
  supplierName    String?
  cashPaid        Decimal  @db.Decimal(12, 2)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch        Branch        @relation(fields: [branchId], references: [id])
  ledgerAccount LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Cascade)

  @@index([branchId, entryDate])
  @@index([ledgerAccountId, entryDate])
}
