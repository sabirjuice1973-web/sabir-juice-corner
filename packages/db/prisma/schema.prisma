  branchId            BigInt
  date                DateTime @db.Date
  salesTotal          Decimal  @db.Decimal(14, 2) @default(0)
  ordersCount         Int      @default(0)
  cashTotal           Decimal  @db.Decimal(14, 2) @default(0)
  cardTotal           Decimal  @db.Decimal(14, 2) @default(0)
  walletTotal         Decimal  @db.Decimal(14, 2) @default(0)
  creditTotal         Decimal  @db.Decimal(14, 2) @default(0)
  discountTotal       Decimal  @db.Decimal(14, 2) @default(0)
  voidCount           Int      @default(0)
  cancelCount         Int      @default(0)
  expenseTotal        Decimal  @db.Decimal(14, 2) @default(0)
  expectedGlasses     Decimal  @db.Decimal(14, 2) @default(0)
  actualGlassesSold   Decimal  @db.Decimal(14, 2) @default(0)
  variancePct         Decimal  @db.Decimal(6, 2)  @default(0)
  computedAt          DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, date])
