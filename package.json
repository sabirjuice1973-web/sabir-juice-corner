{
  "name": "sabir-juice-corner-erp",
  "version": "0.1.0",
  "private": true,
  "description": "Sabir Juice Corner — multi-branch ERP/POS system",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/prisma/seed.ts",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=packages/db/prisma/schema.prisma",
    "db:validate": "prisma validate --schema=packages/db/prisma/schema.prisma",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
