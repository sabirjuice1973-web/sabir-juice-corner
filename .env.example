# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=sjc
POSTGRES_PASSWORD=sjc_dev_password_change_me
POSTGRES_DB=sjc_erp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Prisma uses this single connection string
DATABASE_URL=postgresql://sjc:sjc_dev_password_change_me@localhost:5432/sjc_erp?schema=public

# ─── API (NestJS) ──────────────────────────────────────────────────────────
API_PORT=4000
JWT_ACCESS_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_different_long_random_string
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d

# ─── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
POS_PORT=3000
ADMIN_PORT=3100

# ─── AI (OpenAI assistant) ────────────────────────────────────────────────
# Get a key at platform.openai.com/api-keys — paste it after the = below.
# Default model gpt-4o-mini is the cheapest competent option ($0.15 in / $0.60 out per 1M tokens).
# Set to gpt-4o for higher-quality deep analysis if needed.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Region / Locale ───────────────────────────────────────────────────────
TZ=Asia/Karachi
DEFAULT_CURRENCY=PKR
DEFAULT_LOCALE=en-PK
